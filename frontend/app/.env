# Empty = same-origin. Vite proxies /api/dashboard|campaigns|reja|marketing and
# /webhook to the Node service (:3001), and everything else under /api to FastAPI
# (:8000) — the same split nginx does in production. Absolute URLs here would
# bypass the proxy and fail CORS, since neither backend sends CORS headers.
VITE_API_URL_CRM=
VITE_API_URL_PAYROLL=
