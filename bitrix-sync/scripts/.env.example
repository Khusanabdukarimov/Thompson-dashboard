# Facebook / Meta API credentials
# Copy this to .env (one level up, at bitrix-sync/.env) and fill in real values.

# Primary ad account (used for Meta campaigns / Dilmurod)
META_AD_ACCOUNT_ID=act_XXXXXXXXXXXXXXXXX
META_ACCESS_TOKEN=EAAoJwDMzIzsBRQ...

# Secondary ad account (legacy)
FB_AD_ACCOUNT_ID=act_XXXXXXXXXXXXXXXXX
FB_ACCESS_TOKEN=EAAoJwDMzIzsBRQ...

# Optional: comma-separated list to query multiple accounts at once
# AD_ACCOUNT_IDS=act_111111111,act_222222222,act_333333333

# Meta app credentials (only needed for webhook verification)
FB_APP_ID=0000000000000000
FB_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FB_WEBHOOK_VERIFY_TOKEN=your_verify_token

# Facebook Page ID
FB_PAGE_ID=000000000000000

# API version (default v21.0)
FB_API_VERSION=v21.0
